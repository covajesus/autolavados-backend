APP_NAME=autolavados.cl API
DEBUG=true
API_PREFIX=/api
# Con o sin barra final (ambas formas se aceptan)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,https://autolavados.cl,https://www.autolavados.cl,https://admin.autolavados.cl,https://api.autolavados.cl
# Usuario MySQL debe usar caching_sha2_password (no mysql_native_password en MySQL 8.4+)
DATABASE_URL=mysql+pymysql://usuario:password@localhost:3306/autolavados
JWT_SECRET_KEY=change-me-in-production-use-env
JWT_EXPIRE_MINUTES=10080
DEFAULT_ADMIN_EMAIL=admin@autolavados.cl
DEFAULT_ADMIN_PASSWORD=123456789
