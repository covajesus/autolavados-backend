[Unit]
Description=autolavados.cl CarWash API (FastAPI)
After=network.target mysql.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/autolavados-api
EnvironmentFile=/opt/autolavados-api/.env
ExecStart=/opt/autolavados-api/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
